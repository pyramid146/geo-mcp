# --- Postgres ---
# POSTGRES_USER + POSTGRES_PASSWORD are read by docker-compose.yml at
# container bootstrap only. POSTGRES_DB is the database name used by
# docker-compose AND the Python runtime.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=geo

# --- Runtime role passwords ---
# mcp_admin      — ingest & migrations  (scripts/backup.sh, scripts/migrate.sh, ingest/*/load.sh)
# mcp_ingest     — owns staging tables  (ingest/*/load.sh, migrations/002)
# mcp_readonly   — app runtime role     (Python server reads geo, writes meta)
MCP_ADMIN_PASSWORD=change-me
MCP_INGEST_PASSWORD=change-me
MCP_READONLY_PASSWORD=change-me

# --- Runtime DB connection (read by geo_mcp/config.py) ---
# Defaults are fine for the local docker-compose setup; override only
# if you're pointing the Python server at a DB on another host.
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_USER=mcp_readonly

# --- API key pepper (optional, recommended for production) ---
# When set, API keys are stored as HMAC-SHA256(pepper, raw) rather
# than plain SHA-256. Defence-in-depth: a leaked backup / DB snapshot
# can't be brute-forced offline without also possessing the pepper.
# Validation falls back to legacy plain-SHA256 lookup so pre-pepper
# keys still authenticate — you can introduce the pepper without
# invalidating existing keys. Generate with e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
GEO_MCP_KEY_PEPPER=

# Tailscale IP for docker-compose's dual-bind on postgres
# (container listens on 127.0.0.1:5432 AND ${TAILSCALE_IP}:5432).
TAILSCALE_IP=100.64.0.1

# MCP HTTP server bind address.
#
# RECOMMENDED: 127.0.0.1 — loopback only, never directly reachable from
# the internet even if UFW drifts. If you run Cloudflare Tunnel on the
# same host (scripts/cloudflared/README.md), cloudflared talks to you
# over loopback and this is all you need.
#
# Only set to 0.0.0.0 if you NEED another host on your LAN / VPN to
# reach the server directly (e.g. dev laptop on Tailscale without the
# tunnel). In that case make sure UFW / your firewall blocks the port
# from the open internet — the AuthMiddleware is the only thing keeping
# arbitrary callers out of /mcp.
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8000

# Free EPC Open Data Communities account — register at
# https://epc.opendatacommunities.org/ and DLUHC will email you an API
# key. Used only by ingest/epc/download.sh, not at runtime.
EPC_API_EMAIL=
EPC_API_KEY=

# Self-service signup: the public base URL callers see in verification
# emails, and Resend transactional-email credentials. Leave RESEND_API_KEY
# unset and the server logs the verification URL to stdout instead of
# emailing — fine for local dev, not for anything user-facing.
GEO_MCP_PUBLIC_BASE_URL=http://127.0.0.1:8000
GEO_MCP_FROM_EMAIL=onboarding@resend.dev
RESEND_API_KEY=
