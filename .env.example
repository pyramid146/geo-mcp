POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=geo

MCP_ADMIN_PASSWORD=change-me
MCP_INGEST_PASSWORD=change-me
MCP_READONLY_PASSWORD=change-me

TAILSCALE_IP=100.64.0.1

# MCP HTTP server. Default binds to 127.0.0.1 (loopback only); set to 0.0.0.0
# to listen on all interfaces (e.g. to accept connections over Tailscale).
# No auth on the MCP endpoint until Phase 5 — rely on UFW / Tailscale until then.
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8000

# Free EPC Open Data Communities account — register at
# https://epc.opendatacommunities.org/ and DLUHC will email you an API
# key. Used only by ingest/epc/download.sh, not at runtime.
EPC_API_EMAIL=
EPC_API_KEY=

# Self-service signup: the public base URL callers see in verification
# emails, and Resend transactional-email credentials. Leave RESEND_API_KEY
# unset and the server logs the verification URL to stdout instead of
# emailing — fine for local dev, not for anything user-facing.
GEO_MCP_PUBLIC_BASE_URL=http://127.0.0.1:8000
GEO_MCP_FROM_EMAIL=onboarding@resend.dev
RESEND_API_KEY=
